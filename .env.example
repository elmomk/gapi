# Required
MASTER_KEY=change_me_to_at_least_32_bytes_long_random_string
TS_AUTHKEY=tskey-auth-xxxxx

# API keys (comma-separated key:consumer_name pairs)
API_KEYS=gorilla_coach_key_here:gorilla_coach,life_manager_key_here:life_manager

# Optional tuning
DATABASE_PATH=/app/data/garmin_api.db
HOST=0.0.0.0
PORT=3000
SYNC_RATE_LIMIT_MINS=60
SYNC_DAYS=30
GARMIN_API_DELAY_SECS=5
MAX_CONSECUTIVE_EMPTY_DAYS=5
RUST_LOG=info
